{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scratch-my-table.local/schemas/workflow-package-v1.schema.json",
  "title": "Workflow Package v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "type", "activeWorkflowId", "workflows", "runOrderWorkflowIds"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "type": {
      "type": "string",
      "const": "workflowPackage"
    },
    "activeWorkflowId": {
      "$ref": "#/$defs/id"
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "runOrderWorkflowIds": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/id"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
    }
  }
}

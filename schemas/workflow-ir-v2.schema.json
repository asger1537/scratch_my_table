{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scratch-my-table.local/schemas/workflow-ir-v2.schema.json",
  "title": "Workflow IR v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "workflowId", "name", "steps"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 2
    },
    "workflowId": {
      "$ref": "#/$defs/id"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/step"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "color": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "scalar": {
      "type": ["string", "number", "boolean", "null"]
    },
    "nonNullScalar": {
      "type": ["string", "number", "boolean"]
    },
    "columnIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/id"
      }
    },
    "columnSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columnId", "displayName"],
      "properties": {
        "columnId": {
          "$ref": "#/$defs/id"
        },
        "displayName": {
          "$ref": "#/$defs/displayName"
        }
      }
    },
    "cellFormatPatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fillColor": {
          "$ref": "#/$defs/color"
        }
      },
      "anyOf": [
        {
          "required": ["fillColor"]
        }
      ]
    },
    "cellPatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": {
          "$ref": "#/$defs/expression"
        },
        "format": {
          "$ref": "#/$defs/cellFormatPatch"
        }
      },
      "anyOf": [
        {
          "required": ["value"]
        },
        {
          "required": ["format"]
        }
      ]
    },
    "ruleCase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["when", "then"],
      "properties": {
        "when": {
          "$ref": "#/$defs/expression"
        },
        "then": {
          "$ref": "#/$defs/cellPatch"
        }
      }
    },
    "matchCase": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "when", "then"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "when"
            },
            "when": {
              "$ref": "#/$defs/expression"
            },
            "then": {
              "$ref": "#/$defs/expression"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "then"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "otherwise"
            },
            "then": {
              "$ref": "#/$defs/expression"
            }
          }
        }
      ]
    },
    "expression": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "value"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "caseValue"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "literal"
            },
            "value": {
              "$ref": "#/$defs/scalar"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "columnId"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "column"
            },
            "columnId": {
              "$ref": "#/$defs/id"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "subject", "cases"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "match"
            },
            "subject": {
              "$ref": "#/$defs/expression"
            },
            "cases": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/matchCase"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "args"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "call"
            },
            "name": {
              "type": "string",
              "enum": ["trim", "lower", "upper", "toNumber", "toString", "toBoolean", "collapseWhitespace", "first", "last", "round", "floor", "ceil", "abs"]
            },
            "args": {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "items": {
                "$ref": "#/$defs/expression"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "args"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "call"
            },
            "name": {
              "type": "string",
              "const": "now"
            },
            "args": {
              "type": "array",
              "maxItems": 0
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "args"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "call"
            },
            "name": {
              "type": "string",
              "enum": ["isEmpty", "not"]
            },
            "args": {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "items": {
                "$ref": "#/$defs/expression"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "args"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "call"
            },
            "name": {
              "type": "string",
              "enum": ["split", "atIndex", "extractRegex", "coalesce", "equals", "contains", "startsWith", "endsWith", "matchesRegex", "greaterThan", "lessThan", "add", "subtract", "multiply", "divide", "modulo", "datePart"]
            },
            "args": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "items": {
                "$ref": "#/$defs/expression"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "args"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "call"
            },
            "name": {
              "type": "string",
              "enum": ["and", "or", "concat"]
            },
            "args": {
              "type": "array",
              "minItems": 2,
              "items": {
                "$ref": "#/$defs/expression"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "args"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "call"
            },
            "name": {
              "type": "string",
              "const": "substring"
            },
            "args": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "$ref": "#/$defs/expression"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "args"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "call"
            },
            "name": {
              "type": "string",
              "enum": ["replace", "replaceRegex"]
            },
            "args": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "$ref": "#/$defs/expression"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "name", "args"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "call"
            },
            "name": {
              "type": "string",
              "enum": ["dateDiff", "dateAdd"]
            },
            "args": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": {
                "$ref": "#/$defs/expression"
              }
            }
          }
        }
      ]
    },
    "sortKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columnId", "direction"],
      "properties": {
        "columnId": {
          "$ref": "#/$defs/id"
        },
        "direction": {
          "type": "string",
          "enum": ["asc", "desc"]
        }
      }
    },
    "step": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "text"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "comment"
            },
            "text": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "columnIds"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "scopedRule"
            },
            "columnIds": {
              "$ref": "#/$defs/columnIds"
            },
            "rowCondition": {
              "$ref": "#/$defs/expression"
            },
            "cases": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/ruleCase"
              }
            },
            "defaultPatch": {
              "$ref": "#/$defs/cellPatch"
            }
          },
          "anyOf": [
            {
              "required": ["cases"]
            },
            {
              "required": ["defaultPatch"]
            }
          ]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "columnIds"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "dropColumns"
            },
            "columnIds": {
              "$ref": "#/$defs/columnIds"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "columnId", "newDisplayName"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "renameColumn"
            },
            "columnId": {
              "$ref": "#/$defs/id"
            },
            "newDisplayName": {
              "$ref": "#/$defs/displayName"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "newColumn", "expression"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "deriveColumn"
            },
            "newColumn": {
              "$ref": "#/$defs/columnSpec"
            },
            "expression": {
              "$ref": "#/$defs/expression"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "mode", "condition"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "filterRows"
            },
            "mode": {
              "type": "string",
              "enum": ["keep", "drop"]
            },
            "condition": {
              "$ref": "#/$defs/expression"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "columnId", "delimiter", "outputColumns"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "splitColumn"
            },
            "columnId": {
              "$ref": "#/$defs/id"
            },
            "delimiter": {
              "type": "string",
              "minLength": 1
            },
            "outputColumns": {
              "type": "array",
              "minItems": 2,
              "items": {
                "$ref": "#/$defs/columnSpec"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "columnIds", "separator", "newColumn"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "combineColumns"
            },
            "columnIds": {
              "allOf": [
                {
                  "$ref": "#/$defs/columnIds"
                },
                {
                  "minItems": 2
                }
              ]
            },
            "separator": {
              "type": "string"
            },
            "newColumn": {
              "$ref": "#/$defs/columnSpec"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "columnIds"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "deduplicateRows"
            },
            "columnIds": {
              "$ref": "#/$defs/columnIds"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "sorts"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "sortRows"
            },
            "sorts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/sortKey"
              }
            }
          }
        }
      ]
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scratch-my-table.local/schemas/workflow-ir-v1.schema.json",
  "title": "Workflow IR v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "workflowId", "name", "steps"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "workflowId": {
      "$ref": "#/$defs/id"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/step"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "scalar": {
      "type": ["string", "number", "boolean", "null"]
    },
    "nonNullScalar": {
      "type": ["string", "number", "boolean"]
    },
    "columnTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "columnIds"],
      "properties": {
        "kind": {
          "type": "string",
          "const": "columns"
        },
        "columnIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    },
    "columnSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columnId", "displayName"],
      "properties": {
        "columnId": {
          "$ref": "#/$defs/id"
        },
        "displayName": {
          "$ref": "#/$defs/displayName"
        }
      }
    },
    "expression": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "literal"
            },
            "value": {
              "$ref": "#/$defs/scalar"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "columnId"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "column"
            },
            "columnId": {
              "$ref": "#/$defs/id"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "parts"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "concat"
            },
            "parts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/expression"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "inputs"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "coalesce"
            },
            "inputs": {
              "type": "array",
              "minItems": 2,
              "items": {
                "$ref": "#/$defs/expression"
              }
            }
          }
        }
      ]
    },
    "condition": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "columnId", "treatWhitespaceAsEmpty"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "isEmpty"
            },
            "columnId": {
              "$ref": "#/$defs/id"
            },
            "treatWhitespaceAsEmpty": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "columnId", "value"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "equals"
            },
            "columnId": {
              "$ref": "#/$defs/id"
            },
            "value": {
              "$ref": "#/$defs/nonNullScalar"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "columnId", "value"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "contains"
            },
            "columnId": {
              "$ref": "#/$defs/id"
            },
            "value": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "columnId", "value"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "startsWith"
            },
            "columnId": {
              "$ref": "#/$defs/id"
            },
            "value": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "columnId", "value"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "endsWith"
            },
            "columnId": {
              "$ref": "#/$defs/id"
            },
            "value": {
              "type": "string"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "columnId", "value"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "greaterThan"
            },
            "columnId": {
              "$ref": "#/$defs/id"
            },
            "value": {
              "$ref": "#/$defs/nonNullScalar"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "columnId", "value"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "lessThan"
            },
            "columnId": {
              "$ref": "#/$defs/id"
            },
            "value": {
              "$ref": "#/$defs/nonNullScalar"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "conditions"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "and"
            },
            "conditions": {
              "type": "array",
              "minItems": 2,
              "items": {
                "$ref": "#/$defs/condition"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "conditions"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "or"
            },
            "conditions": {
              "type": "array",
              "minItems": 2,
              "items": {
                "$ref": "#/$defs/condition"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "condition"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "not"
            },
            "condition": {
              "$ref": "#/$defs/condition"
            }
          }
        }
      ]
    },
    "sortKey": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columnId", "direction"],
      "properties": {
        "columnId": {
          "$ref": "#/$defs/id"
        },
        "direction": {
          "type": "string",
          "enum": ["asc", "desc"]
        }
      }
    },
    "step": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "target", "value", "treatWhitespaceAsEmpty"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "fillEmpty"
            },
            "target": {
              "$ref": "#/$defs/columnTarget"
            },
            "value": {
              "$ref": "#/$defs/nonNullScalar"
            },
            "treatWhitespaceAsEmpty": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "target", "trim", "collapseWhitespace", "case"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "normalizeText"
            },
            "target": {
              "$ref": "#/$defs/columnTarget"
            },
            "trim": {
              "type": "boolean"
            },
            "collapseWhitespace": {
              "type": "boolean"
            },
            "case": {
              "type": "string",
              "enum": ["preserve", "lower", "upper"]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "columnId", "newDisplayName"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "renameColumn"
            },
            "columnId": {
              "$ref": "#/$defs/id"
            },
            "newDisplayName": {
              "$ref": "#/$defs/displayName"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "newColumn", "expression"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "deriveColumn"
            },
            "newColumn": {
              "$ref": "#/$defs/columnSpec"
            },
            "expression": {
              "$ref": "#/$defs/expression"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "mode", "condition"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "filterRows"
            },
            "mode": {
              "type": "string",
              "enum": ["keep", "drop"]
            },
            "condition": {
              "$ref": "#/$defs/condition"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "columnId", "delimiter", "outputColumns"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "splitColumn"
            },
            "columnId": {
              "$ref": "#/$defs/id"
            },
            "delimiter": {
              "type": "string",
              "minLength": 1
            },
            "outputColumns": {
              "type": "array",
              "minItems": 2,
              "items": {
                "$ref": "#/$defs/columnSpec"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "target", "separator", "newColumn"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "combineColumns"
            },
            "target": {
              "allOf": [
                {
                  "$ref": "#/$defs/columnTarget"
                },
                {
                  "properties": {
                    "columnIds": {
                      "minItems": 2
                    }
                  }
                }
              ]
            },
            "separator": {
              "type": "string"
            },
            "newColumn": {
              "$ref": "#/$defs/columnSpec"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "target"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "deduplicateRows"
            },
            "target": {
              "$ref": "#/$defs/columnTarget"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "type", "sorts"],
          "properties": {
            "id": {
              "$ref": "#/$defs/id"
            },
            "type": {
              "type": "string",
              "const": "sortRows"
            },
            "sorts": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/sortKey"
              }
            }
          }
        }
      ]
    }
  }
}

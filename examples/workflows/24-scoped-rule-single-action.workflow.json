{
  "version": 2,
  "workflowId": "wf_scoped_rule_single_action",
  "name": "Scoped rule single action",
  "description": "Applies one combined value-and-format patch to VIP status cells.",
  "steps": [
    {
      "id": "step_vip_status_single_action",
      "type": "scopedRule",
      "columnIds": [
        "col_status"
      ],
      "rowCondition": {
        "kind": "call",
        "name": "equals",
        "args": [
          {
            "kind": "column",
            "columnId": "col_vip"
          },
          {
            "kind": "literal",
            "value": true
          }
        ]
      },
      "defaultPatch": {
        "value": {
          "kind": "call",
          "name": "coalesce",
          "args": [
            {
              "kind": "call",
              "name": "lower",
              "args": [
                {
                  "kind": "call",
                  "name": "trim",
                  "args": [
                    {
                      "kind": "value"
                    }
                  ]
                }
              ]
            },
            {
              "kind": "literal",
              "value": "vip-review"
            }
          ]
        },
        "format": {
          "fillColor": "#fff2cc"
        }
      }
    }
  ]
}

{
  "version": 2,
  "workflowId": "wf_calculate_priority_score",
  "name": "Calculate priority score",
  "steps": [
    {
      "id": "step_calculate_priority_score",
      "type": "deriveColumn",
      "newColumn": {
        "columnId": "col_priority_score",
        "displayName": "priority_score"
      },
      "expression": {
        "kind": "match",
        "subject": {
          "kind": "call",
          "name": "toNumber",
          "args": [
            {
              "kind": "column",
              "columnId": "col_balance"
            }
          ]
        },
        "cases": [
          {
            "pattern": {
              "kind": "range",
              "lt": 0
            },
            "then": {
              "kind": "literal",
              "value": 3
            }
          },
          {
            "pattern": {
              "kind": "range",
              "gte": 0,
              "lte": 200
            },
            "then": {
              "kind": "literal",
              "value": 2
            }
          },
          {
            "pattern": {
              "kind": "wildcard"
            },
            "then": {
              "kind": "literal",
              "value": 1
            }
          }
        ]
      }
    }
  ]
}
